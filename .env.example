# ==========================================
# CryptoRadar 环境变量配置示例
# ==========================================
# 使用方法：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 编辑 .env 文件填入实际值
# 3. 重启应用使配置生效
# ==========================================

# ------------------------------------------
# 💰 币安 API 配置（只读权限）- 必填
# ------------------------------------------
# ⚠️ 安全提示：
# 1. 请仅授予「只读」权限，切勿开放交易/提现权限
# 2. 建议设置 IP 白名单
# 3. 定期轮换密钥（建议每 90 天）
# ------------------------------------------
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ------------------------------------------
# 📢 推送通知配置 - 可选
# ------------------------------------------

# 全局推送总开关（默认 true）
GLOBAL_PUSH_ENABLED=true

# 飞书机器人
FEISHU_ENABLED=false
FEISHU_WEBHOOK_URL=

# 企业微信机器人
WECOM_ENABLED=false
WECOM_WEBHOOK_URL=

# ------------------------------------------
# 🖥️ 端口配置 - 可选
# ------------------------------------------

# 后端端口（默认 8000）
BACKEND_PORT=8000

# 前端端口（默认 5173）
FRONTEND_PORT=5173

# ------------------------------------------
# 📂 路径配置 - 可选（Docker 部署时使用）
# ------------------------------------------

# 日志目录（默认 logs）
# LOG_DIR=/app/logs

# 数据库目录（默认当前目录）
# DB_DIR=/app/data
