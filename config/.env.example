# ==========================================
# CryptoRadar Docker 环境变量配置示例
# ==========================================
# 使用方法：
# 1. 复制此文件为 .env：
#    cp .env.example .env
# 2. 编辑 .env 填入实际值
# 3. 启动 Docker：
#    docker-compose up --build -d
# ==========================================

# ------------------------------------------
# 💰 币安 API 配置（只读权限）- 必填
# ------------------------------------------
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ------------------------------------------
# 📢 推送通知配置 - 可选
# ------------------------------------------

# 全局推送总开关
GLOBAL_PUSH_ENABLED=true

# 飞书机器人
FEISHU_ENABLED=false
FEISHU_WEBHOOK_URL=

# 企业微信机器人
WECOM_ENABLED=false
WECOM_WEBHOOK_URL=

# ------------------------------------------
# 🖥️ 端口配置 - 可选
# ------------------------------------------

# 后端端口（默认 8000）
BACKEND_PORT=8000

# 前端端口（默认 5174）
FRONTEND_PORT=5174

# ------------------------------------------
# 📂 路径配置 - 可选
# ------------------------------------------
# 注意：这些路径是 Docker 容器内的路径，无需修改
# DB_DIR=/app/data
# LOG_DIR=/app/logs
